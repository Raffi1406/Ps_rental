# Salin file ini menjadi ".env" lalu sesuaikan.
# JANGAN PERNAH commit file .env (jika berisi kredensial asli) ke GitHub.

FLASK_SECRET_KEY=ganti-dengan-string-acak-yang-panjang

# ======================================================================
# MODE 1: LocalStack (S3 emulator lokal, gratis, tanpa akun AWS asli)
# ======================================================================
# Kredensial untuk LocalStack BEBAS diisi apa saja (tidak divalidasi),
# umumnya cukup pakai "test" / "test".
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# Jalankan LocalStack lebih dulu (lihat README bagian LocalStack), lalu:
# - Jika app dijalankan langsung di komputer (python app.py):
AWS_ENDPOINT_URL=http://localhost:4566
# - Jika app dijalankan lewat docker-compose (satu network dengan container localstack):
#   AWS_ENDPOINT_URL=http://localstack:4566
#   AWS_ENDPOINT_URL_PUBLIC=http://localhost:4566

AWS_ENDPOINT_URL_PUBLIC=

# ======================================================================
# MODE 2: AWS S3 asli (production / opsional)
# ======================================================================
# Untuk pindah ke AWS S3 asli: isi kredensial IAM asli anda, lalu KOSONGKAN
# AWS_ENDPOINT_URL dan AWS_ENDPOINT_URL_PUBLIC (biarkan tidak bernilai).
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_REGION=ap-southeast-1

# Nama bucket S3 khusus untuk Cloud Vault.
# Untuk LocalStack: nama bebas, aplikasi akan membuatnya otomatis.
# Untuk AWS asli: harus unik secara global.
VAULT_BUCKET=ps-rental-cloud-vault

MAX_UPLOAD_MB=100
PRESIGNED_URL_EXPIRE=3600

# Lokasi file database SQLite (opsional, default: rental.db di root proyek)
DATABASE_PATH=
